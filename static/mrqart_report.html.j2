<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ title }}</title>
<meta name="viewport" content="width=device-width,initial-scale=1">
<style>
  :root { --bg:#0b1020; --card:#11162a; --muted:#94a3b8; --text:#e5e7eb;
          --ok:#10b981; --bad:#ef4444; --na:#6b7280; --accent:#60a5fa; --border:#1f2937; }
  *{box-sizing:border-box}
  body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Inter,Ubuntu,"Helvetica Neue",Arial;background:var(--bg);color:var(--text)}
  header{padding:18px 20px;background:linear-gradient(90deg,#0b1020,#0f172a 60%);border-bottom:1px solid var(--border)}
  h1{margin:0;font-weight:700;font-size:18px;letter-spacing:.5px}
  .sub{color:var(--muted);font-size:12px;margin-top:2px}
  .toolbar{display:flex;gap:12px;align-items:center;padding:12px 20px;border-bottom:1px solid var(--border);background:#0d1326}
  .tool{display:flex;gap:8px;align-items:center}
  .tool label{font-size:12px;color:var(--muted)}
  input[type="text"],select{background:#0b1224;color:var(--text);border:1px solid var(--border);border-radius:8px;padding:8px 10px}
  input[type="text"]{min-width:220px}
  .cb{accent-color:var(--accent)}
  .wrap{padding:16px 20px}
  .card{background:var(--card);border:1px solid var(--border);border-radius:14px;overflow:auto;box-shadow:0 10px 30px rgba(0,0,0,.25)}
  table{width:100%;border-collapse:separate;border-spacing:0}
  thead th{position:sticky;top:0;background:#0d1326;border-bottom:1px solid var(--border);padding:10px 12px;font-size:12px;text-align:left;color:var(--muted)}
  tbody td{border-bottom:1px solid var(--border);padding:10px 12px;font-size:13px;vertical-align:top}
  tbody tr:hover{background:#0f1833}
  .nowrap{white-space:nowrap}
  .num{text-align:right;font-variant-numeric:tabular-nums}
  .center{text-align:center}
  .badge{display:inline-block;padding:4px 8px;border-radius:999px;color:#fff;font-size:11px}
  .chip{padding:2px 8px;border-radius:999px;font-size:11px;color:#fff}
  .chip.ok{background:var(--ok)} .chip.bad{background:var(--bad)} .chip.na{background:var(--na)}
  footer{color:var(--muted);font-size:11px;padding:12px 20px}
</style>
</head>
<body>
<header>
  <h1>{{ title }}</h1>
  <div class="sub">Updated {{ updated }} • Showing latest {{ count }} entries</div>
</header>

<div class="toolbar">
  <div class="tool">
    <label for="q">Search</label>
    <input id="q" type="text" placeholder="project, sequence, subject, station…">
  </div>
  <div class="tool">
    <label for="status">Status</label>
    <select id="status">
      <option value="">All</option>
      <option value="NONCONFORM">Non-conforming</option>
      <option value="NO_TEMPLATE">No template</option>
      <option value="OK">OK</option>
    </select>
  </div>
  <div class="tool">
    <input id="onlyfail" class="cb" type="checkbox">
    <label for="onlyfail">Only issues</label>
  </div>
</div>

<div class="wrap">
  <div class="card">
    <table id="t">
      <thead>
        <tr>
          <th>Script Time</th>
          <th>Acq Time</th>
          <th>Project</th>
          <th>Sequence</th>
          <th>Subject</th>
          <th>Series</th>
	  <th>Station</th>
	  <th>Physicist</th>
          <th>Conforms</th>
          <th>Errors</th>
          <th>Error Detail</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
      {% for r in rows %}
        <tr data-status="{{ (r.status or '')|e }}">
          <td class="nowrap">{{ (r.script_ts or '')|e }}</td>
          <td class="nowrap">{{ (r.acq_ts or '')|e }}</td>
          <td>{{ (r.project or '')|e }}</td>
          <td>{{ (r.sequence or '')|e }}</td>
          <td>{{ (r.subid or '')|e }}</td>
          <td class="num">{{ (r.series or '')|e }}</td>
          <td>{{ (r.station or '')|e }}</td>
	  <td>{{ (r.physicist or '')|e }}</td>
          <td class="center">
            {% if r.conforms is sameas true %}<span class="chip ok">True</span>
            {% elif r.conforms is sameas false %}<span class="chip bad">False</span>
            {% else %}<span class="chip na">N/A</span>
            {% endif %}
          </td>
          <td class="num">{{ (r.error_count or 0)|e }}</td>
          <td>
            {% if r.errors %}
              {% if r.errors is string %}
                {{ r.errors|e }}
              {% else %}
                <ul>{% for e in r.errors %}<li>{{ e|e }}</li>{% endfor %}</ul>
              {% endif %}
            {% endif %}
          </td>
          <td>
            {% set c = {'OK':'#10b981','NONCONFORM':'#ef4444','NO_TEMPLATE':'#f59e0b'}[r.status] if r.status in ['OK','NONCONFORM','NO_TEMPLATE'] else '#6b7280' %}
            <span class="badge" style="background: {{ c }};">{{ (r.status or '')|e }}</span>
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</div>

<footer>DB entries are appended to a JSONL log and this page is regenerated by the MRQART job.</footer>

<script>
  const q = document.getElementById('q');
  const statusSel = document.getElementById('status');
  const onlyFail = document.getElementById('onlyfail');
  const tbody = document.querySelector('#t tbody');
  function matches(row, needle) {
    if (!needle) return true;
    const txt = row.innerText.toLowerCase();
    return txt.includes(needle);
  }
  function show(row, ok) { row.style.display = ok ? '' : 'none'; }
  function applyFilters() {
    const needle = q.value.trim().toLowerCase();
    const status = statusSel.value;
    const rows = Array.from(tbody.querySelectorAll('tr'));
    rows.forEach(r => {
      const st = r.getAttribute('data-status') || '';
      const matchesStatus = !status || st === status;
      const hasIssue = (st === 'NONCONFORM' || st === 'NO_TEMPLATE');
      const wantIssues = !onlyFail.checked || hasIssue;
      show(r, matches(r, needle) && matchesStatus && wantIssues);
    });
  }
  q.addEventListener('input', applyFilters);
  statusSel.addEventListener('change', applyFilters);
  onlyFail.addEventListener('change', applyFilters);
</script>
</body>
</html>

